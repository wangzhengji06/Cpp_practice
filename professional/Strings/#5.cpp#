#include <iostream>
#include <print>
#include <string>
#include <vector>

using namespace std;

int main() {
  string input;
  vector<string> words;
  while (cin >> input) {
    if (input == "*") {
      break;
    }
    words.push_back(input);
  }

  // calculate the longest
  size_t maxLength{};

  for (const auto &word : words) {
    if (word.length() > maxLength) {
      maxLength = word.length();
    }
  }

  // print the words five in a row
  for (size_t i = 0; i < words.size(); ++i) {
    print("|{0:^{1}}", words[i], maxLength + 2);
    
    if ((i + 1) % 5 == 0) {
      println("|");
    }
  }

  if (words.size() % 5 != 0) {
    println("|");

  }
}
